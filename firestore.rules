rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'sandraandersoncy@gmail.com' || request.auth.token.email == 'sandracastro626@gmail.com');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'sandraandersoncy@gmail.com' || 
        request.auth.token.email == 'sandracastro626@gmail.com' || 
        (isEmailVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'administrador')
      );
    }

    function isDocente() {
      return isSignedIn() && isEmailVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'docente';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Allow any signed-in user to at least check their own record existence and read it
      // This MUST be first and simple to avoid recursion
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // Allow hardcoded admins absolute access
      allow read, write: if isSignedIn() && (
        request.auth.token.email == 'sandraandersoncy@gmail.com' || 
        request.auth.token.email == 'sandracastro626@gmail.com'
      );

      // Other administrative/docente permissions
      allow get: if isSignedIn() && (isAdmin() || isDocente());
      allow list: if isSignedIn() && isAdmin();
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin() && userId != 'admin_001';
    }

    match /preguntas/{preguntaId} {
      allow read: if isEmailVerified();
      allow create: if isEmailVerified() && (isAdmin() || isDocente());
      allow update: if isEmailVerified() && (isAdmin() || (isDocente() && resource.data.creadoPor == request.auth.uid));
      allow delete: if isEmailVerified() && isAdmin();
    }

    match /simulacros/{simulacroId} {
      allow read: if isEmailVerified();
      allow create: if isEmailVerified() && (isAdmin() || isDocente());
      allow update: if isEmailVerified() && (isAdmin() || (isDocente() && existing().creadoPor == request.auth.uid));
      allow delete: if isEmailVerified() && isAdmin();
    }

    match /intentos/{intentoId} {
      allow read: if isEmailVerified() && (isOwner(existing().estudianteId) || isAdmin() || isDocente());
      allow create: if isEmailVerified() && incoming().estudianteId == request.auth.uid;
      allow update, delete: if false; // Attempts are immutable
    }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }
  }
}
