rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData(request.auth.uid).rol == role;
    }

    function isAdmin() {
      return hasRole('administrador');
    }

    function isDocente() {
      return hasRole('docente');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'nombreCompleto', 'email', 'rol', 'estado']) &&
             data.id is string && data.id.size() <= 128 &&
             data.nombreCompleto is string && data.nombreCompleto.size() <= 200 &&
             data.email is string && data.email.size() <= 100 &&
             data.rol in ['administrador', 'docente', 'estudiante'] &&
             data.estado in ['activo', 'inactivo'];
    }

    function isValidPregunta(data) {
      return data.keys().hasAll(['id', 'enunciado', 'opciones', 'respuestaCorrecta', 'competencia', 'componente']) &&
             data.id is string &&
             data.enunciado is string && data.enunciado.size() <= 5000 &&
             data.respuestaCorrecta in ['A', 'B', 'C', 'D'];
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin() || isDocente());
      allow list: if isAdmin(); // Only admins can list all users
      
      allow create: if isAdmin() && isValidUser(incoming());
      
      allow update: if (isAdmin() && isValidUser(incoming())) ||
                    (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['nombreCompleto', 'password']));
      
      allow delete: if isAdmin() && userId != 'admin_001';
    }

    match /preguntas/{preguntaId} {
      allow read: if isEmailVerified();
      allow create: if isEmailVerified() && (isAdmin() || isDocente()) && isValidPregunta(incoming());
      allow update: if isEmailVerified() && (isAdmin() || (isDocente() && existing().creadoPor == request.auth.uid)) && isValidPregunta(incoming());
      allow delete: if isEmailVerified() && isAdmin();
    }

    match /simulacros/{simulacroId} {
      allow read: if isEmailVerified();
      allow create: if isEmailVerified() && (isAdmin() || isDocente());
      allow update: if isEmailVerified() && (isAdmin() || (isDocente() && existing().creadoPor == request.auth.uid));
      allow delete: if isEmailVerified() && isAdmin();
    }

    match /intentos/{intentoId} {
      allow read: if isEmailVerified() && (isOwner(existing().estudianteId) || isAdmin() || isDocente());
      allow create: if isEmailVerified() && incoming().estudianteId == request.auth.uid;
      allow update, delete: if false; // Attempts are immutable
    }

    // --- Connection Test ---
    match /test/connection {
      allow read: if true;
    }
  }
}
